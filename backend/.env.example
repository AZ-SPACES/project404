# Arkesel SMS
ARKESEL_API_KEY=your_arkesel_api_key
ARKESEL_SENDER_ID=SENER_ID

# Gmail SMTP
GMAIL_USERNAME=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# JWT
JWT_SECRET=your_jwt_secret_at_least_64_characters_long_for_security

# Database
DB_URL=jdbc:postgresql://DB_URL
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=port

# Cloudinary for profile images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# TURN server (replace with a real random secret in production: openssl rand -hex 32)
TURN_SECRET=your_turn_server_secret
TURN_HOST=turn.yourdomain.com

# CAPTCHA — get from https://dashboard.hcaptcha.com/
# Leave blank in dev (challenges are issued but auto-passed)
HCAPTCHA_SECRET=

# Signs bypass tokens — generate with: openssl rand -hex 32
CHALLENGE_HMAC_SECRET=your_challenge_hmac_secret

# Signs payment-proof QR codes — dedicated secret (never reuse JWT_SECRET)
# generate with: openssl rand -hex 32
PAYMENT_PROOF_HMAC_SECRET=your_payment_proof_hmac_secret

# IPs of your load balancer / Cloudflare so X-Forwarded-For is trusted
# In dev: leave blank. In prod: your LB's IP(s)
TRUSTED_PROXY_IPS=
TRUSTED_IPS=

#Admin
ADMIN_BOOTSTRAP_EMAIL=replace your first email from sign up

# TOTP secret encryption key — AES-256-GCM (openssl rand -base64 32)
TOTP_ENCRYPTION_KEY=

# Firebase Push Notifications (Optional — stringified JSON or Base64 encoded string of firebase-service-account.json)
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_BASE64=

