# Copy this file to .env and fill in all values before running docker compose.

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=aza_db
DB_USERNAME=aza_user
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme

# ── JWT / Security ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=

# Generate with: openssl rand -base64 32
CHALLENGE_HMAC_SECRET=

# ── SMS (Arkesel) ─────────────────────────────────────────────────────────────
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=AZA

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── WebRTC TURN server ────────────────────────────────────────────────────────
TURN_SECRET=
TURN_HOST=turn.aza.systems

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# First user with this email gets the ADMIN role on first login
ADMIN_BOOTSTRAP_EMAIL=

# ── hCaptcha (optional) ───────────────────────────────────────────────────────
HCAPTCHA_SECRET=

# ── Waitlist ──────────────────────────────────────────────────────────────────
# Shared secret between aza-web (Next.js) and the backend.
# Must be identical in both aza-web/.env.local and this file.
WAITLIST_INTERNAL_SECRET=

# ── PassKit / Apple Wallet (optional) ────────────────────────────────────────
PASSKIT_API_KEY=
PASSKIT_API_SECRET=
PASSKIT_TEMPLATE_ID=
